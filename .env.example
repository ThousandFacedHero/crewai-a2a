# Required
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-key-here

# Optional — global defaults
LLM_MODEL=gpt-4o
A2A_PORT=5000
A2A_PEER_URL=http://localhost:5001
LOG_LEVEL=INFO
OTEL_EXPORTER_ENDPOINT=

# Per-agent LLM overrides (optional — falls back to globals above)
# Useful for separate LiteLLM virtual keys with different rate limits or models.
# COORDINATOR_LLM_API_KEY=
# COORDINATOR_LLM_MODEL=
# COORDINATOR_LLM_BASE_URL=
# RESEARCHER_LLM_API_KEY=
# RESEARCHER_LLM_MODEL=
# RESEARCHER_LLM_BASE_URL=
# WRITER_LLM_API_KEY=
# WRITER_LLM_MODEL=
# WRITER_LLM_BASE_URL=

# Graphiti (optional — enables long-term memory when set)
GRAPHITI_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=
